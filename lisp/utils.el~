
(defun call-with-auto-input (function prompt-value-alist)
;; 自动填入函数所需参数：
;;   格式：
;; ('function
;; '(("prompt1" . ("value1")
;;  ("prompt2" . ("value2")
;;  ...
;;   )))

  (cl-letf (((symbol-function 'read-string)
             (lambda (prompt &optional initial-input history default-value inherit-input-method)
               (catch 'found
                 (dolist (pair prompt-value-alist)
                   (when (string-match-p (car pair) prompt)
                     (throw 'found (cdr pair))))
                 initial-input))))
    (call-interactively function)))

(provide 'utils)
