(use-package lsp-pyright
  :ensure t
  :custom (lsp-pyright-langserver-command "pyright") ;; or basedpyright
  :hook (python-mode . (lambda ()
                          (require 'lsp-pyright)
                          (lsp))))  ; or lsp-deferred

;;;LSP bridge
(add-to-list 'load-path "~/.emacs.d/lisp/lsp-bridge/")
(use-package lsp-bridge
  :load-path "~/.emacs.d/lsp-bridge/"
  ;; 关键设置：指定使用 python3，避免 pypy3 导致的模块找不到问题 [citation:9]
  :init
  (setq lsp-bridge-python-command "python3")
  ;; 如果你希望补全菜单出现得更“手动”一些，可以开启这个选项，然后用命令手动调出
  ;; (setq lsp-bridge-complete-manually t)
  :config
  ;; 全局开启 lsp-bridge 模式
  (global-lsp-bridge-mode))


;;LSP
(use-package lsp-mode
  :init
  ;; set prefix for lsp-command-keymap (few alternatives - "C-l", "C-c l")
  (setq sp-install-server t)
  (setq	lsp-keymap-prefix "C-c l")
  :hook (;; replace XXX-mode with concrete major-mode(e. g. python-mode)
         (python-mode . lsp)
	 (c++-mode . lsp);;need clangd 
	 (c-mode . lsp) ;; need clangd
	 (csharp-ts-mode . lsp) ;;M-x lsp-install-server RET omnisharp RET.
	 (kotlin-mode . lsp) ;;need kotlin 
	 ;; if you want which-key integration
         (lsp-mode . lsp-enable-which-key-integration))
  :commands lsp)

